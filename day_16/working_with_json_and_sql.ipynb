   "source": [
    "import certifi\n",
    "import requests\n",
    "\n",
    "url = 'https://api.exchangerate-api.com/v4/latest/INR'\n",
    "\n",
    "response = requests.get(url, verify=certifi.where())\n",
    "response.raise_for_status()\n",
    "\n",
    "import pandas as pd\n",
    "import io\n",
    "df = pd.read_json(io.StringIO(response.text))\n",
    "print(df.shape)\n",
    "df"
   ]
  },
